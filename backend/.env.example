PORT=4200
NODE_ENV=development

# Yerel PostgreSQL — gerçek kullanıcı/şifre ile .env dosyanda doldur
# Docker (backend/docker-compose.yml): port 5433 →
# DATABASE_URL="postgresql://aidatpanel:aidatpanel@127.0.0.1:5433/aidatpanel?schema=public"
DATABASE_URL="postgresql://aidatpanel:CHANGE_ME@localhost:5432/aidatpanel?schema=public"

# En az 32 karakter rastgele string (ör. openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters_long
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_here_minimum_32_characters_long
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="30d"

# Virgülle ayrılmış origin listesi (Flutter web veya tarayıcıdan API testi).
# Android/iOS native isteklerde tarayıcı CORS’u yoktur; yalnızca web build için gerekir.
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# Email Service - Resend (şifre sıfırlama e-postası)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL="AidatPanel <onboarding@resend.dev>"
# PASSWORD_RESET_EXPIRES_MINUTES=60
# PASSWORD_RESET_APP_HINT="Mobil uygulamada şifre sıfırlama ekranına bu kodu girin."

# test.py — POST /auth/reset-password E2E: sunucu her forgot sonrası son kodu bu dosyaya JSON satırı yazar (üretimde kullanma)
# AIDATPANEL_E2E_RESET_LOG=/tmp/aidatpanel-reset-e2e.jsonl

# Auth rate limit (varsayılan: production=5, development=50). Çok düşükse test.py 429 alır.
# AUTH_RATE_LIMIT_MAX=100

# Firebase Push Notifications
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Twilio SMS/WhatsApp
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_PHONE_FROM=+1xxxxxxxx

# RevenueCat Subscription Validation
# REVENUECAT_API_KEY=rg_xxxxxxxx
# REVENUECAT_WEBHOOK_SECRET=whsec_xxxxxxxx

# ==========================================
# Docker ile tam E2E (Postgres + API + test.py)
# ==========================================
#   cd backend && ./scripts/docker-test.sh
# API: http://127.0.0.1:4200/api/v1 — şifre sıfırlama kodu: ./e2e-data/reset.jsonl
# Durdur: docker compose down

# ==========================================
# NOTES
# ==========================================
# - Asla gerçek .env dosyasını GitHub'a push etme!
# - .gitignore'da .env zaten ignore ediliyor
# - Üretim ortamında (production) farklı değerler kullan
# - Bu repoda daha önce gerçek DATABASE_URL paylaşıldıysa Neon/DB şifresini rotate et
